<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Coltrane Med Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,300;0,6..96,400;0,6..96,700;0,6..96,900;1,6..96,300;1,6..96,400;1,6..96,700&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">
  <style>
    /* Holograph Design System v1.8 - Exact implementation */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    
    :root {
      /* Neutrals */
      --color-neutral-950: #080C10;
      --color-neutral-900: #0F1419;
      --color-neutral-850: #161D26;
      --color-neutral-800: #1E2733;
      --color-neutral-700: #2E3D4E;
      --color-neutral-600: #3F5568;
      --color-neutral-500: #567085;
      --color-neutral-400: #7A97AE;
      --color-neutral-300: #A8BDC9;
      --color-neutral-200: #C8D8E2;
      --color-neutral-100: #E2EBF0;
      
      /* Teal / Iridescent cyan */
      --color-teal-700:  #0D5C64;
      --color-teal-500:  #1B9AA8;
      --color-teal-400:  #2DB5C4;
      --color-teal-300:  #5ECDD8;
      --color-teal-200:  #96E0E8;
      
      /* Violet */
      --color-violet-300: #A991E2;
      
      /* Amber */
      --color-amber-300: #F0A040;
      
      /* Green */
      --color-green-300: #5DB872;
      
      /* Red */
      --color-red-400: #E05040;
      
      /* Backgrounds */
      --bg-base:      var(--color-neutral-950);
      --bg-surface:   var(--color-neutral-900);
      --bg-overlay:   var(--color-neutral-850);
      --bg-raised:    var(--color-neutral-800);
      --bg-subtle:    var(--color-neutral-700);
      
      /* Text */
      --text-primary:    var(--color-neutral-100);
      --text-secondary:  var(--color-neutral-300);
      --text-tertiary:   var(--color-neutral-400);
      
      /* Brand */
      --brand-teal:      var(--color-teal-300);
      --brand-violet:    var(--color-violet-300);
      --brand-amber:     var(--color-amber-300);
      --brand-green:     var(--color-green-300);
      
      /* Status */
      --status-success:  var(--color-green-300);
      --status-warning:  var(--color-amber-300);
      --status-error:    var(--color-red-400);
      
      /* Borders */
      --border-subtle:   rgba(162, 189, 201, 0.12);
      --border-default:  rgba(162, 189, 201, 0.22);
      --border-strong:   rgba(162, 189, 201, 0.40);
      
      /* Spacing */
      --space-1:  0.25rem;
      --space-2:  0.5rem;
      --space-3:  0.75rem;
      --space-4:  1rem;
      --space-5:  1.25rem;
      --space-6:  1.5rem;
      --space-8:  2rem;
      --space-10: 2.5rem;
      
      /* Fonts */
      --font-display: 'Bodoni Moda', serif;
      --font-body:    'IBM Plex Sans', sans-serif;
      --font-mono:    'IBM Plex Mono', monospace;
      
      /* Type scale */
      --text-xs:   0.75rem;
      --text-sm:   0.875rem;
      --text-base: 1rem;
      --text-lg:   1.125rem;
      --text-xl:   1.25rem;
      --text-2xl:  1.563rem;
      --text-3xl:  1.953rem;
      --text-4xl:  2.441rem;
      
      /* Radii */
      --radius-sm:   3px;
      --radius-md:   6px;
      --radius-lg:   10px;
      --radius-xl:   16px;
      --radius-full: 9999px;
      
      /* Shadows */
      --shadow-sm:   0 1px 3px rgba(0,0,0,0.4), 0 1px 2px rgba(0,0,0,0.3);
      --shadow-md:   0 4px 12px rgba(0,0,0,0.5), 0 2px 4px rgba(0,0,0,0.3);
      --shadow-lg:   0 10px 30px rgba(0,0,0,0.6), 0 4px 8px rgba(0,0,0,0.3);
    }
    
    body {
      background: var(--bg-base);
      color: var(--text-secondary);
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
    }
    
    .container {
      max-width: 1160px;
      margin: 0 auto;
      padding: var(--space-6);
    }
    
    /* Header */
    h1 {
      font-family: var(--font-display);
      font-size: var(--text-4xl);
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: var(--space-2);
    }
    
    .subtitle {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--text-secondary);
      margin-bottom: var(--space-8);
    }
    
    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--space-6);
      margin-bottom: var(--space-8);
    }
    
    .stat-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
      box-shadow: var(--shadow-md);
    }
    
    .stat-label {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      margin-bottom: var(--space-3);
    }
    
    .stat-value {
      font-family: var(--font-mono);
      font-size: 2.5rem;
      font-weight: 300;
      color: var(--brand-teal);
      line-height: 1;
      margin-bottom: var(--space-3);
    }
    
    .stat-detail {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--text-secondary);
    }
    
    /* Badges */
    .badge {
      display: inline-block;
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-full);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      font-weight: 500;
      margin-right: var(--space-2);
      margin-bottom: var(--space-2);
    }
    
    .badge-meth { background: rgba(94, 205, 216, 0.15); color: var(--brand-teal); }
    .badge-gaba { background: rgba(169, 145, 226, 0.15); color: var(--brand-violet); }
    .badge-melo { background: rgba(240, 160, 64, 0.15); color: var(--brand-amber); }
    .badge-tyl { background: rgba(93, 184, 114, 0.15); color: var(--brand-green); }
    
    /* Buttons */
    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-bottom: var(--space-8);
    }
    
    .btn {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      padding: var(--space-2) var(--space-4);
      border-radius: var(--radius-md);
      border: 1px solid var(--border-default);
      background: var(--bg-raised);
      color: var(--text-secondary);
      cursor: pointer;
      transition: all 0.18s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .btn:hover {
      border-color: var(--brand-teal);
      color: var(--brand-teal);
      background: rgba(94, 205, 216, 0.08);
    }
    
    .btn-primary {
      background: var(--brand-teal);
      border-color: var(--brand-teal);
      color: var(--bg-base);
    }
    
    .btn-primary:hover {
      background: var(--color-teal-400);
      border-color: var(--color-teal-400);
    }
    
    /* Table */
    .table-wrapper {
      background: var(--bg-surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-xl);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      margin-bottom: var(--space-8);
    }
    
    table {
      width: 100%;
      border-collapse: collapse;
    }
    
    th {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      font-weight: 500;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      background: rgba(8, 12, 16, 0.5);
      padding: var(--space-4);
      text-align: left;
      border-bottom: 1px solid var(--border-subtle);
      position: sticky;
      top: 0;
    }
    
    td {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--text-primary);
      padding: var(--space-4);
      border-bottom: 1px solid var(--border-subtle);
    }
    
    tr:last-child td {
      border-bottom: none;
    }
    
    tr.done {
      opacity: 0.5;
    }
    
    tr.done td:nth-child(n+3) {
      text-decoration: line-through;
    }
    
    tr.next {
      border-left: 3px solid var(--brand-teal);
      background: rgba(94, 205, 216, 0.05);
    }
    
    /* Checkbox */
    input[type="checkbox"] {
      width: 18px;
      height: 18px;
      border-radius: var(--radius-sm);
      cursor: pointer;
      accent-color: var(--brand-teal);
    }
    
    /* Status */
    .status-ok {
      color: var(--status-success);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
    }
    
    .status-bad {
      color: var(--status-error);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
    }
    
    /* Footer */
    .footer {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--text-tertiary);
      padding-top: var(--space-6);
      border-top: 1px solid var(--border-subtle);
      line-height: 1.7;
    }
    
    .footer-data {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      margin-top: var(--space-2);
      color: var(--text-tertiary);
    }
    
    /* Responsive */
    @media (max-width: 767px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }
      
      th:nth-child(5), td:nth-child(5) {
        display: none;
      }
    }
  </style>
</head>
<body>
  <script src="/auth-check.js"></script>
  <div class="container">
    <h1>Coltrane Med Tracker</h1>
    <div class="subtitle">Medication schedule and progress tracking</div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Next Dose</div>
        <div class="stat-value" id="nextWhen">—</div>
        <div class="stat-detail" id="nextMeds">—</div>
        <div class="stat-detail" id="countdown" style="margin-top: var(--space-2); color: var(--text-tertiary);">—</div>
      </div>
      
      <div class="stat-card">
        <div class="stat-label">Today's Progress</div>
        <div class="stat-value" id="todayProg">0 / 0</div>
        <div class="stat-detail">completed doses</div>
      </div>
      
      <div class="stat-card" style="background: rgba(94, 205, 216, 0.05); border-color: rgba(94, 205, 216, 0.3);">
        <div class="stat-label">Alarm Status</div>
        <div style="margin: var(--space-4) 0;">
          <button id="enableNotif" class="btn btn-primary">Enable Notifications</button>
          <button id="testAlarm" class="btn">Test Alarm</button>
        </div>
        <div id="alarmState" class="stat-detail">Off</div>
      </div>
    </div>

    <!-- Controls -->
    <div class="controls">
      <button id="showAll" class="btn btn-primary">All Doses</button>
      <button id="show24" class="btn">Next 24h</button>
      <button id="showToday" class="btn">Today</button>
      <button id="hideDone" class="btn">Hide Done: Off</button>
      <button id="dense" class="btn">Compact: Off</button>
      <button id="reset" class="btn">Reset Checks</button>
    </div>

    <!-- Schedule Table -->
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Done</th>
            <th>When</th>
            <th>Medications</th>
            <th>Notes</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="rows"></tbody>
      </table>
    </div>

    <!-- Footer -->
    <div class="footer">
      <strong>Regimen:</strong> Methocarbamol q8h (7a/3p/11p) • Gabapentin q12h (11a/11p) • Tylenol q12h (11a/11p) • Meloxicam q24h (9p, daily liquid)
      <div class="footer-data" id="persistInfo"></div>
    </div>
  </div>

<script>
const KEY='coltrane-med-unified-v3';
const COOKIE_KEY='coltrane_med_unified_v3';

function getCookie(name){
  const parts=document.cookie.split(';').map(v=>v.trim());
  const hit=parts.find(v=>v.startsWith(name+'='));
  return hit ? decodeURIComponent(hit.split('=').slice(1).join('=')) : '';
}

function setCookie(name,value,days=365){
  const d=new Date(); d.setTime(d.getTime()+days*24*60*60*1000);
  document.cookie=`${name}=${encodeURIComponent(value)}; expires=${d.toUTCString()}; path=/; SameSite=Lax`;
}

function loadState(){
  let ls={}; let ck={};
  try{ ls=JSON.parse(localStorage.getItem(KEY)||'{}')||{}; }catch(e){ ls={}; }
  try{ ck=JSON.parse(getCookie(COOKIE_KEY)||'{}')||{}; }catch(e){ ck={}; }
  return Object.keys(ls).length ? ls : ck;
}

function persistState(state){
  const payload=JSON.stringify(state);
  try{ localStorage.setItem(KEY,payload); }catch(e){}
  try{ setCookie(COOKIE_KEY,payload); }catch(e){}
}

const state=loadState();
const SEED_KEY='__seed_mar4_anchors';
let mode='all'; let hideDone=false; let dense=false;

const events=new Map();
const add=(iso, meds, notes='')=>{if(!events.has(iso))events.set(iso,{meds:[],notes:[]});events.get(iso).meds.push(...meds); if(notes)events.get(iso).notes.push(notes)};
const toLocalIso=(d)=>{
  const y=d.getFullYear();
  const m=String(d.getMonth()+1).padStart(2,'0');
  const day=String(d.getDate()).padStart(2,'0');
  const hh=String(d.getHours()).padStart(2,'0');
  const mm=String(d.getMinutes()).padStart(2,'0');
  const ss=String(d.getSeconds()).padStart(2,'0');
  return `${y}-${m}-${day}T${hh}:${mm}:${ss}`;
};
const addEveryHours=(startIso,hours,meds,endIso,notes='')=>{
  const end=new Date(endIso);
  let cur=new Date(startIso);
  while(cur<end){
    add(toLocalIso(cur),meds,notes);
    const next=new Date(cur);
    next.setHours(next.getHours()+hours);
    cur=next;
  }
};

const horizon='2026-03-18T00:00:00';
addEveryHours('2026-03-03T21:00:00',24,['Meloxicam'],'2026-03-18T00:00:00','q24h (daily liquid)');
addEveryHours('2026-03-03T23:00:00',12,['Gabapentin','Tylenol'],'2026-03-18T00:00:00','q12h cadence');
addEveryHours('2026-03-04T07:00:00',8,['Methocarbamol'],'2026-03-18T00:00:00','q8h cadence');

const rows=[...events.entries()].sort((a,b)=>new Date(a[0])-new Date(b[0])).map((e)=>({id:`dose:${e[0]}`,iso:e[0],...e[1]}));

if(!state[SEED_KEY]){
  ['2026-03-03T21:00:00','2026-03-03T23:00:00','2026-03-04T07:00:00','2026-03-04T11:00:00'].forEach(iso=>{ state[`dose:${iso}`]=true; });
  state[SEED_KEY]=true;
  persistState(state);
}

const fmt=iso=>new Date(iso).toLocaleString('en-US',{weekday:'short',month:'short',day:'numeric',hour:'numeric',minute:'2-digit'});
const medClass=m=>m.startsWith('Meth')?'badge-meth':m.startsWith('Gaba')?'badge-gaba':m.startsWith('Melo')?'badge-melo':'badge-tyl';
const isToday=dt=>{const n=new Date();return dt.toDateString()===n.toDateString()};

function filtered(list){
  const now=new Date();
  return list.filter(r=>{
    const dt=new Date(r.iso); const done=!!state[r.id];
    if(hideDone && done) return false;
    if(mode==='today') return isToday(dt);
    if(mode==='24h') return dt>=new Date(now.getTime()-60*60*1000) && dt<=new Date(now.getTime()+24*60*60*1000);
    return true;
  });
}

function nextDue(){
  const now=new Date();
  return rows.find(r=>!state[r.id] && new Date(r.iso)>=new Date(now.getTime()-5*60*1000));
}

function render(){
  const body=document.getElementById('rows'); body.innerHTML='';
  const list=filtered(rows); const nd=nextDue();
  list.forEach(r=>{
    const tr=document.createElement('tr'); if(state[r.id]) tr.classList.add('done');
    const meds=[...new Set(r.meds)];
    const status=new Date(r.iso)<new Date()?(state[r.id]?'<span class="status-ok">✓ done</span>':'<span class="status-bad">⚠ overdue</span>'):'upcoming';
    tr.innerHTML=`<td><input type="checkbox" ${state[r.id]?'checked':''} data-id="${r.id}"></td>
      <td style="font-family: var(--font-body);">${fmt(r.iso)}</td>
      <td><div>${meds.map(m=>`<span class="badge ${medClass(m)}">${m}</span>`).join('')}</div></td>
      <td style="color: var(--text-tertiary); font-family: var(--font-body);">${[...new Set(r.notes)].join('; ')||'-'}</td>
      <td>${status}</td>`;
    if(nd && nd.id===r.id) tr.classList.add('next');
    body.appendChild(tr);
  });

  const todayRows=rows.filter(r=>isToday(new Date(r.iso))); const done=todayRows.filter(r=>state[r.id]).length;
  document.getElementById('todayProg').textContent=`${done} / ${todayRows.length||0}`;

  const n=nextDue();
  if(!n){document.getElementById('nextWhen').textContent='All done'; document.getElementById('nextMeds').textContent='—'; document.getElementById('countdown').textContent='';}
  else {
    document.getElementById('nextWhen').textContent=fmt(n.iso).split(',')[1].trim();
    document.getElementById('nextMeds').innerHTML=[...new Set(n.meds)].map(m=>`<span class="badge ${medClass(m)}">${m}</span>`).join('');
    const ms=new Date(n.iso)-new Date();
    const abs=Math.abs(ms); const h=Math.floor(abs/3600000), m=Math.floor((abs%3600000)/60000);
    document.getElementById('countdown').textContent= ms>=0 ? `in ${h}h ${m}m` : `${h}h ${m}m overdue`;
  }

  document.getElementById('hideDone').textContent=`Hide Done: ${hideDone?'On':'Off'}`;
  document.getElementById('dense').textContent=`Compact: ${dense?'On':'Off'}`;
  document.getElementById('persistInfo').textContent=`✓ Data saved locally on ${location.hostname}`;
}

document.addEventListener('change',e=>{ if(e.target.matches('input[type=checkbox][data-id]')){ state[e.target.dataset.id]=e.target.checked; persistState(state); render(); }});

document.getElementById('showAll').onclick=()=>{mode='all';render()};
document.getElementById('show24').onclick=()=>{mode='24h';render()};
document.getElementById('showToday').onclick=()=>{mode='today';render()};
document.getElementById('hideDone').onclick=()=>{hideDone=!hideDone;render()};
document.getElementById('dense').onclick=()=>{dense=!dense;render()};
document.getElementById('reset').onclick=()=>{
  if(confirm('Reset all checkmarks?')) {
    try{ localStorage.removeItem(KEY); }catch(e){}
    setCookie(COOKIE_KEY,'{}',-1);
    location.reload();
  }
};

let alarmFiredFor='';
async function enableNotif(){
  if(!('Notification' in window)){document.getElementById('alarmState').textContent='Not supported';return;}
  const p=await Notification.requestPermission();
  document.getElementById('alarmState').textContent=`Permission: ${p}`;
}
document.getElementById('enableNotif').onclick=enableNotif;
document.getElementById('testAlarm').onclick=()=>fireAlarm('Test alarm','Coltrane med reminder test');

function fireAlarm(title,body){
  try{ if(Notification.permission==='granted') new Notification(title,{body}); }catch(e){}
  try{ navigator.vibrate && navigator.vibrate([300,200,300]); }catch(e){}
  try{
    const ctx=new (window.AudioContext||window.webkitAudioContext)();
    const o=ctx.createOscillator(); const g=ctx.createGain();
    o.connect(g); g.connect(ctx.destination); o.type='sine'; o.frequency.value=880; g.gain.value=.03; o.start(); setTimeout(()=>o.stop(),500);
  }catch(e){}
}

setInterval(()=>{
  render();
  const n=nextDue(); if(!n) return;
  const now=new Date(); const due=new Date(n.iso);
  const minutes=Math.floor((due-now)/60000);
  if(minutes<=0 && alarmFiredFor!==n.id){
    alarmFiredFor=n.id;
    fireAlarm('Med dose due now', `${fmt(n.iso)} • ${[...new Set(n.meds)].join(' + ')}`);
  }
},30000);

render();
</script>
</body>
</html>
